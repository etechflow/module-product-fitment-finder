<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="catalog_list_item"/>
    <body>
        <attribute name="class" value="page-with-filter"/>
        <attribute name="class" value="page-products"/>
        <attribute name="class" value="catalog-category-view"/>

        <referenceContainer name="sidebar.main">
            <block class="ETechFlow\ProductFitmentFinder\Block\Widget\PartFinder"
                   name="vehiclecompat.find.form"
                   template="ETechFlow_ProductFitmentFinder::partfinder/widget.phtml"
                   before="vehiclecompat.sidebar.summary"
                   cacheable="false"/>
            <block class="ETechFlow\ProductFitmentFinder\Block\FilterChips"
                   name="vehiclecompat.sidebar.summary"
                   template="ETechFlow_ProductFitmentFinder::find/sidebar.phtml"
                   cacheable="false">
                <arguments>
                    <!-- always render the "Your Selection" panel, even with no filters,
                         so the configurable sidebar_no_filters message can show -->
                    <argument name="show_when_empty" xsi:type="boolean">true</argument>
                </arguments>
            </block>
            <!-- My Garage: self-hides until enabled in admin (Saved Garage → Enable).
                 Placed alongside the finder so its Save Selection button + the garage
                 share a page (the garage template defines etechflowGarageSave). -->
            <block class="ETechFlow\ProductFitmentFinder\Block\Garage"
                   name="vehiclecompat.garage"
                   template="ETechFlow_ProductFitmentFinder::garage/widget.phtml"
                   after="vehiclecompat.sidebar.summary"
                   cacheable="false"/>
        </referenceContainer>

        <referenceContainer name="content">
            <block class="ETechFlow\ProductFitmentFinder\Block\FindResults"
                   name="vehiclecompat.find.results"
                   template="ETechFlow_ProductFitmentFinder::find/results.phtml"
                   cacheable="false"/>
        </referenceContainer>

        <referenceBlock name="page.main.title">
            <action method="setPageTitle">
                <argument translate="true" name="title" xsi:type="string">Find Your Parts</argument>
            </action>
        </referenceBlock>
    </body>
</page>
