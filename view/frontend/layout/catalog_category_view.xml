<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <!--
                "Listing page header" placement (USAGE.md): the Part Finder form
                right above the product grid so customers can filter the catalog by
                their vehicle without leaving the category. getFindUrl() detects the
                current category and refines it in place (FilterByVehicle), so the
                Find Parts button reloads THIS category with the chosen vehicle.
            -->
            <block class="ETechFlow\ProductFitmentFinder\Block\Widget\PartFinder"
                   name="vehiclecompat.category.partfinder"
                   template="ETechFlow_ProductFitmentFinder::partfinder/widget.phtml"
                   before="-">
                <arguments>
                    <argument name="vc_location" xsi:type="string">product_list</argument>
                    <argument name="vc_size" xsi:type="string">sm</argument>
                </arguments>
            </block>
            <block class="ETechFlow\ProductFitmentFinder\Block\FilterChips"
                   name="vehiclecompat.category.filter.chips"
                   template="ETechFlow_ProductFitmentFinder::find/category-chips.phtml"
                   after="vehiclecompat.category.partfinder"/>
            <!-- My Garage travels with the finder: same vc_location so it renders
                 only when the finder is placed here (Placement = Product List). -->
            <block class="ETechFlow\ProductFitmentFinder\Block\Garage"
                   name="vehiclecompat.category.garage"
                   template="ETechFlow_ProductFitmentFinder::garage/widget.phtml"
                   after="vehiclecompat.category.filter.chips">
                <arguments>
                    <argument name="vc_location" xsi:type="string">product_list</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
