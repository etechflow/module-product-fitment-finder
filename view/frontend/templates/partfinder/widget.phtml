    }
    .vc-partfinder--md .vc-partfinder__heading { font-size: 1.7rem; }
    .vc-partfinder .vc-actions { margin-top: .25rem; }
    .vc-partfinder .vc-save-selection {
        display: flex; align-items: center; justify-content: center; gap: .4rem;
        width: 100%; margin-top: .4rem; padding: .55rem; background: #fff;
        border: 1px solid #d1d5db; border-radius: .45rem; color: #374151;
        font-size: 12.5px; font-weight: 700; cursor: pointer; font-family: inherit;
    }
    .vc-partfinder .vc-save-selection:hover { background: #f9fafb; }
    /* v1.2.0 — OEM / part-number search, shown under the finder */
    .vc-partfinder .vc-oem { margin-top: .9rem; }
    .vc-partfinder .vc-oem-or {
        display: flex; align-items: center; text-align: center; margin: .3rem 0 .7rem;
        color: #9ca3af; font-size: .7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .06em;
    }
    .vc-partfinder .vc-oem-or::before,
    .vc-partfinder .vc-oem-or::after { content: ""; flex: 1; height: 1px; background: #e5e7eb; }
    .vc-partfinder .vc-oem-or span { padding: 0 .6rem; }
    .vc-partfinder .vc-oem-label {
        font-size: .8rem; font-weight: 700; color: #374151; margin-bottom: .4rem;
    }
    .vc-partfinder .vc-oem-row { display: flex; gap: .4rem; }
    .vc-partfinder .vc-oem-input {
        flex: 1; min-width: 0; padding: .55rem .7rem; font-size: .85rem; color: #0E1025;
        background: #fff; border: 1px solid #d1d5db; border-radius: .45rem; font-family: inherit;
    }
    .vc-partfinder .vc-oem-input:focus {
        outline: none; border-color: var(--vc-accent, #0535F5);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--vc-accent, #0535F5) 18%, transparent);
    }
    .vc-partfinder .vc-oem-btn {
        flex-shrink: 0; padding: .55rem 1rem; font-size: .82rem; font-weight: 700;
        color: #fff; background: var(--vc-accent, #0535F5); border: 0; border-radius: .45rem;
        cursor: pointer; font-family: inherit; white-space: nowrap;
    }
    .vc-partfinder .vc-oem-btn:hover { filter: brightness(.92); }
    /* sidebar context: let the form fill the column */
    .sidebar .vc-partfinder { max-width: none; margin-bottom: 14px; }
</style>
