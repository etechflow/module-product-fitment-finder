<?php
/**
 * Host wrapper for the shared Find-Your-Parts form fragment.
 *
 * Provides the Alpine x-data scope (the vehicleCompatPartFinder factory is
 * loaded globally by view/frontend/layout/default.xml) and the shared CSS,
 * then INCLUDES partfinder/form.phtml so the form markup stays a single source
 * of truth. The included fragment runs in this scope, so $block (the PartFinder
 * host, which exposes getMakeLabel()/getFindButtonText()/… ) and $escaper are
 * available to it.
 *
 * @var \ETechFlow\ProductFitmentFinder\Block\Widget\PartFinder $block
 * @var \Magento\Framework\Escaper $escaper
 */
$findUrl   = $block->getFindUrl();
$vcSize    = (string) ($block->getData('vc_size') ?: 'md');
$vcHeading = (string) $block->getPartFinderHeading();
?>
<?php /* Server-resolved selection (make/model/year/part NAMES) for a pre-filled
        finder — so it shows the vehicle name and Save Selection works on the
        results page, where the URL carries only IDs. The finder JS reads this. */ ?>
<?php $vcPreselect = $block->getPreselection(); ?>
<?php if ($vcPreselect !== null): ?>
<script>window.etechflowPreselect = <?= /* @noEscape */ json_encode($vcPreselect, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP) ?>;</script>
<?php endif; ?>
<?php /* Shared combobox CSS — pure static <style>, no dynamic content. */ ?>
<?php include $block->getTemplateFile('ETechFlow_ProductFitmentFinder::partfinder/styles.phtml'); ?>
<div class="vc-partfinder vc-partfinder--<?= $escaper->escapeHtmlAttr($vcSize) ?>"
     style="--vc-accent:<?= $escaper->escapeHtmlAttr($block->getAccentColour()) ?>"
     x-data="vehicleCompatPartFinder('<?= $escaper->escapeJs($findUrl) ?>')">
    <?php if ($vcHeading !== ''): ?>
        <h3 class="vc-partfinder__heading"><?= $escaper->escapeHtml($vcHeading) ?></h3>
    <?php endif; ?>
    <?php include $block->getTemplateFile('ETechFlow_ProductFitmentFinder::partfinder/form.phtml'); ?>

    <?php /* v1.2.0 — OEM / part-number search, now shown WITH the finder (was
            Find-page only). Renders only when enabled in admin (Config → OEM /
            Part-Number Search → Enable). Native GET <form> → submits to the Find
            page (getFindUrl), which runs the attribute LIKE search. Kept OUTSIDE
            the Alpine goToFindParts flow on purpose so it works without JS and its
            query stays shareable/bookmarkable. */ ?>
    <?php if ($block->isOemSearchEnabled()): $vcOemTip = $block->getOemTooltip(); ?>
        <div class="vc-oem">
            <div class="vc-oem-or"><span><?= $escaper->escapeHtml(__('or')) ?></span></div>
            <form method="get" action="<?= $escaper->escapeUrl($block->getFindUrl()) ?>" class="vc-oem-form">
                <div class="vc-oem-label"><?= $escaper->escapeHtml($block->getOemSearchLabel()) ?></div>
                <div class="vc-oem-row">
                    <input type="text" name="oem"
                           value="<?= $escaper->escapeHtmlAttr($block->getOemTerm()) ?>"
                           placeholder="<?= $escaper->escapeHtmlAttr($block->getOemSearchPlaceholder()) ?>"
                           aria-label="<?= $escaper->escapeHtmlAttr($block->getOemSearchLabel()) ?>"
                           <?php if ($vcOemTip !== ''): ?>title="<?= $escaper->escapeHtmlAttr($vcOemTip) ?>"<?php endif; ?>
                           class="vc-oem-input" maxlength="64" autocomplete="off">
                    <button type="submit" class="vc-oem-btn">
                        <?= $escaper->escapeHtml($block->getOemButtonText()) ?>
                    </button>
                </div>
                <?php /* preserve any vehicle filters already in the URL (Find page refine) */ ?>
                <?php foreach (['make_id', 'model_id', 'year', 'part_id'] as $vcK):
                    $vcV = (string) $block->getRequest()->getParam($vcK);
                    if ($vcV !== '' && $vcV !== '0'): ?>
                    <input type="hidden" name="<?= $escaper->escapeHtmlAttr($vcK) ?>" value="<?= $escaper->escapeHtmlAttr($vcV) ?>">
                <?php endif; endforeach; ?>
            </form>
        </div>
    <?php endif; ?>
</div>
