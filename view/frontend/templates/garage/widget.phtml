<?php
/**
 * "My Garage" widget.
 *
 * @var \ETechFlow\ProductFitmentFinder\Block\Garage $block
 * @var \Magento\Framework\Escaper $escaper
 */
if (!$block->isEnabled()) {
    return;
}
$storageKey = $block->getStorageKey();
$maxEntries = $block->getMaxEntries();
?>
<?php $garageTooltip = $block->getGarageTooltip(); ?>
<div class="etechflow-vc-garage" x-data="etechflowGarage('<?= $escaper->escapeJs($storageKey) ?>', <?= (int) $maxEntries ?>)" x-init="load()" @etechflow-garage-updated.window="load()" x-cloak
     <?php if ($garageTooltip !== ''): ?>title="<?= $escaper->escapeHtmlAttr($garageTooltip) ?>"<?php endif; ?>>
    <div class="etechflow-vc-garage__panel">
        <div class="etechflow-vc-garage__title"><?= $escaper->escapeHtml($block->getGarageTitle()) ?></div>

        <!-- v1.1.1: Empty state — render an inviting prompt instead of going invisible.
             Tells the customer the feature exists and how to use it. Configurable copy via
             Stores → Config → Vehicle Compatibility → Customer-Facing Copy → Garage Empty Prompt. -->
        <template x-if="vehicles.length === 0">
            <div class="etechflow-vc-garage__empty">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/>
                </svg>
                <p class="etechflow-vc-garage__empty-prompt"><?= $escaper->escapeHtml($block->getGarageEmptyPrompt()) ?></p>
            </div>
        </template>

        <template x-if="vehicles.length > 0">
            <div>
                <ul class="etechflow-vc-garage__list">
                    <template x-for="(v, idx) in vehicles" :key="idx">
                        <li class="etechflow-vc-garage__item">
                            <button type="button"
                                    @click="useVehicle(v)"
                                    class="etechflow-vc-garage__use"
                                    x-text="v.label"></button>
                            <button type="button"
                                    @click="remove(idx)"
                                    class="etechflow-vc-garage__remove"
                                    aria-label="<?= $escaper->escapeHtmlAttr($block->getGarageRemoveLabel()) ?>"
                                    title="<?= $escaper->escapeHtmlAttr($block->getGarageRemoveLabel()) ?>">×</button>
                        </li>
                    </template>
                </ul>
                <button type="button" @click="clear()" class="etechflow-vc-garage__clear">
                    <?= $escaper->escapeHtml($block->getGarageClearButton()) ?>
                </button>
            </div>
        </template>
    </div>
</div>
<?php /* etechflowGarage() + etechflowGarageSave() moved to the global
        js/part-finder.js (loaded on every page) so the finder's Save Selection
        button works wherever the finder is placed, not only on the page hosting
        this widget. */ ?>
