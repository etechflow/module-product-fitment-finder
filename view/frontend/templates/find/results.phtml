<?php
declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\ProductListItem;
use ETechFlow\ProductFitmentFinder\Block\FindResults;
use Magento\Framework\Escaper;

/** @var FindResults $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

$collection   = $block->getProductCollection();
$count        = (int) $collection->getSize();
$chips        = $block->getFilterChips();
$hasAnyFilter = $block->hasAnyFilter();
$pagerHtml    = $block->getPagerHtml();

$productListItemViewModel = null;
try {
    $productListItemViewModel = $viewModels->require(ProductListItem::class);
} catch (\Throwable $e) { /* fall back */ }

$viewMode         = 'grid';
$imageDisplayArea = 'category_page_grid';
$showDescription  = false;
$templateType     = \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
$eagerLoadImagesCount = 4;
?>
<?php /* v1.2.1: surface the accent colour as a CSS custom property scoped to this
        wrapper. Theme can also override globally via --etechflow-vc-accent in your own CSS. */ ?>
<div class="vc-find-page" style="max-width:1280px;margin:0 auto;padding:16px 1rem 48px;font-family:inherit;--etechflow-vc-accent:<?= $escaper->escapeHtmlAttr($block->getAccentColour()) ?>">

    <h1 style="font-size:1.75rem;font-weight:900;color:#0E1025;margin:0 0 12px;letter-spacing:-.01em">
        <?= $escaper->escapeHtml($block->getFindPageTitle()) ?>
    </h1>

    <?php /* v1.2.0 — OEM/part-number search box. Renders only when the admin
            has enabled OEM search (Stores → Config → Vehicle Compatibility →
            OEM / Part-Number Search → Enable). Uses GET so the query stays
            shareable + cacheable. */ ?>
    <?php if ($block->isOemSearchEnabled()): $oemTooltip = $block->getOemTooltip(); ?>
    <form method="get" action="" class="vc-oem-search" style="max-width:480px;margin:0 0 18px;font-family:inherit">
        <label for="vc-oem-input" style="display:block;font-size:.85rem;font-weight:600;color:#374151;margin-bottom:6px">
            <?= $escaper->escapeHtml($block->getOemSearchLabel()) ?>
        </label>
        <div style="display:flex;gap:8px">
            <input id="vc-oem-input" type="text" name="oem"
                   value="<?= $escaper->escapeHtmlAttr($block->getOemTerm()) ?>"
                   placeholder="<?= $escaper->escapeHtmlAttr($block->getOemSearchPlaceholder()) ?>"
                   <?php if ($oemTooltip !== ''): ?>title="<?= $escaper->escapeHtmlAttr($oemTooltip) ?>"<?php endif; ?>
                   style="flex:1;padding:.55rem .8rem;font-size:.9rem;border:1px solid #d1d5db;border-radius:.4rem;font-family:inherit"
                   maxlength="64"
                   autocomplete="off">
            <button type="submit"
                    style="padding:.55rem 1.1rem;background:var(--etechflow-vc-accent, #0535F5);color:#fff;border:0;border-radius:.4rem;font-weight:700;font-size:.85rem;cursor:pointer;font-family:inherit">
                <?= $escaper->escapeHtml($block->getOemButtonText()) ?>
            </button>
        </div>
        <?php /* preserve any vehicle filters when OEM is searched */ ?>
        <?php foreach (['make_id','model_id','year','part_id'] as $k):
            $v = (string) $block->getRequest()->getParam($k);
            if ($v !== '' && $v !== '0'): ?>
            <input type="hidden" name="<?= $escaper->escapeHtmlAttr($k) ?>" value="<?= $escaper->escapeHtmlAttr($v) ?>">
        <?php endif; endforeach; ?>
    </form>
    <?php endif; ?>

    <?php if (!empty($chips)): ?>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin:0 0 16px">
            <?php foreach ($chips as $c): ?>
                <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;background:<?= $escaper->escapeHtmlAttr($c['color']) ?>;color:#fff;border-radius:20px;font-size:.78rem;font-weight:700">
                    <span style="opacity:.85;font-weight:500"><?= $escaper->escapeHtml($c['label']) ?>:</span>
                    <span><?= $escaper->escapeHtml($c['value']) ?></span>
                </span>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>

    <?php if (!$hasAnyFilter): ?>
        <div style="padding:60px 0;text-align:center;background:#f7f8fb;border-radius:14px">
            <p style="font-size:1.05rem;color:#374151;font-weight:700;margin:0 0 8px"><?= $escaper->escapeHtml($block->getEmptyStateMessage()) ?></p>
            <p style="font-size:.85rem;color:#6b7280;margin:0"><?= $escaper->escapeHtml($block->getUseFormPrompt()) ?></p>
        </div>
    <?php elseif ($count === 0): ?>
        <div style="padding:60px 0;text-align:center;background:#fef2f2;border-radius:14px;border:1px solid #fecaca">
            <p style="font-size:1.05rem;color:#991b1b;font-weight:700;margin:0 0 8px"><?= $escaper->escapeHtml($block->getNoResultsTitle()) ?></p>
            <p style="font-size:.85rem;color:#6b7280;margin:0"><?= $escaper->escapeHtml($block->getNoResultsHint()) ?></p>
        </div>
    <?php else: ?>
        <p style="font-size:.9rem;color:#374151;font-weight:600;margin:0 0 18px">
            <?= $escaper->escapeHtml(__('%1 product(s) match your selection', $count)) ?>
        </p>

        <?php
        $items = array_values($collection->getItems());
        // Use Hyva's ProductListItem cards ONLY under an actual Hyva theme. On
        // Luma/custom themes the ViewModel may exist (Hyva module installed) but
        // renders empty, so we use the built-in fallback card below — keeping the
        // grid populated on every theme.
        $useHyvaCards = $productListItemViewModel !== null && $block->isHyvaTheme();
        ?>
        <section class="py-6" id="product-list" aria-label="<?= $escaper->escapeHtmlAttr(__('Product list')) ?>" tabindex="-1">
            <div class="products wrapper mode-grid products-grid">
                <ul role="list"
                    class="mx-auto pt-4 pb-8 grid gap-2.5 grid-cols-2 sm:grid-cols-3 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5<?= $useHyvaCards ? '' : ' vc-results-grid' ?>">
                    <?php foreach ($items as $i => $product): ?>
                        <?php if ($i < $eagerLoadImagesCount):
                            $product->setData('image_custom_attributes', ['loading' => 'eager', 'fetchpriority' => 'high']);
                        endif; ?>
                        <li class="flex flex-col">
                            <?php
                                $itemHtml = '';
                                if ($useHyvaCards) {
                                    try {
                                        $itemHtml = (string) $productListItemViewModel->getItemHtml(
                                            $product,
                                            $block,
                                            $viewMode,
                                            $templateType,
                                            $imageDisplayArea,
                                            $showDescription
                                        );
                                    } catch (\Throwable $e) { $itemHtml = ''; }
                                }
                                if (trim($itemHtml) !== ''):
                                    echo /* @noEscape */ $itemHtml;
                                else:
                                /* Non-Hyva (Luma / custom theme) fallback. The Hyva
                                   ProductListItem ViewModel only exists under Hyva, so
                                   without this branch the grid is empty on every other
                                   theme. Render a real product card from the block's own
                                   helpers (image / url / price) + a standard add-to-cart
                                   so the Find page shows products on EVERY theme. */
                                $vcUrl   = $block->getProductDetailUrl($product);
                                $vcImg   = $block->getProductImageUrl($product);
                                $vcName  = (string) $product->getName();
                                $vcPrice = $block->formatPrice($product);
                            ?>
                                <div class="vc-card">
                                    <a class="vc-card-media" href="<?= $escaper->escapeUrl($vcUrl) ?>" tabindex="-1" aria-hidden="true">
                                        <?php if ($vcImg !== ''): ?>
                                            <img src="<?= $escaper->escapeUrl($vcImg) ?>"
                                                 alt="<?= $escaper->escapeHtmlAttr($vcName) ?>"
                                                 width="240" height="240"
                                                 loading="<?= $i < $eagerLoadImagesCount ? 'eager' : 'lazy' ?>">
                                        <?php endif; ?>
                                    </a>
                                    <a class="vc-card-name" href="<?= $escaper->escapeUrl($vcUrl) ?>"><?= $escaper->escapeHtml($vcName) ?></a>
                                    <?php if ($vcPrice !== ''): ?>
                                        <div class="vc-card-price"><?= $escaper->escapeHtml($vcPrice) ?></div>
                                    <?php endif; ?>
                                    <form class="vc-card-form" action="<?= $escaper->escapeUrl($block->getAddToCartUrl($product)) ?>" method="post">
                                        <input type="hidden" name="form_key" value="<?= $escaper->escapeHtmlAttr($block->getFormKey()) ?>">
                                        <input type="hidden" name="product" value="<?= (int) $product->getId() ?>">
                                        <input type="hidden" name="qty" value="1">
                                        <button type="submit" class="vc-card-cart"><?= $escaper->escapeHtml(__('Add to Cart')) ?></button>
                                    </form>
                                </div>
                            <?php endif; ?>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        </section>

        <?= /* @noEscape */ $pagerHtml ?>
    <?php endif; ?>

</div>
<?php /* Fallback grid + card styles. The .vc-results-grid class is only added to
        the <ul> on non-Hyva themes (where Tailwind isn't compiled), so Hyva's own
        grid is untouched; the .vc-card rules style the fallback cards everywhere. */ ?>
<style>
    .vc-find-page .vc-results-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;list-style:none;margin:0;padding:0}
    @media(min-width:640px){.vc-find-page .vc-results-grid{grid-template-columns:repeat(3,1fr)}}
    @media(min-width:1024px){.vc-find-page .vc-results-grid{grid-template-columns:repeat(4,1fr)}}
    .vc-find-page .vc-results-grid>li{display:flex;flex-direction:column}
    .vc-card{display:flex;flex-direction:column;height:100%;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;background:#fff}
    .vc-card-media{display:block;aspect-ratio:1/1;background:#f7f8fb}
    .vc-card-media img{width:100%;height:100%;object-fit:contain;display:block}
    .vc-card-name{display:block;padding:10px 12px 4px;font-size:.86rem;font-weight:600;line-height:1.3;color:#0E1025;text-decoration:none}
    .vc-card-name:hover{color:var(--etechflow-vc-accent,#0535F5)}
    .vc-card-price{padding:2px 12px 0;font-size:.98rem;font-weight:800;color:#0E1025}
    .vc-card-form{margin-top:auto;padding:10px 12px 12px}
    .vc-card-cart{width:100%;padding:.55rem;background:var(--etechflow-vc-accent,#0535F5);color:#fff;border:0;border-radius:.4rem;font-size:.8rem;font-weight:700;cursor:pointer;font-family:inherit}
    .vc-card-cart:hover{filter:brightness(.92)}
</style>
